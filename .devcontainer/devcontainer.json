{
  "name": "NeuroSense FX Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/postgres:1": {
      "version": "13",
      "username": "neurosensefx",
      "password": "neurosensefx_dev_123",
      "database": "neurosensefx_dev"
    },
    "ghcr.io/devcontainers/features/redis:1": {
      "version": "7"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "svelte.svelte-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--ipc=host"
  ],
  "mounts": [
    "source=${localWorkspaceFolder}/dist,target=/workspaces/neurosensefx/dist,type=bind"
  ],
  "remoteUser": "node",
  "postCreateCommand": "npm install && ./scripts/setup_claude.sh && ./scripts/setup_codespace_db.sh",
  "postStartCommand": "./scripts/setup_codespace_db.sh"
}